# =============================================================================
# HiMewo — required environment variables / secrets (NAMES ONLY, no values)
# =============================================================================
# SECURITY: never commit real values. Set the actual values in each platform's
# secret manager (Replit Secrets, Railway Variables, Cloudflare Pages env, or
# Supabase). This file only documents WHICH keys are needed and WHERE they go.
#
# When migrating to a new Replit account, add the "Replit dev workspace" keys
# below in Tools > Secrets. The Railway / Cloudflare / Supabase keys live on
# those external platforms, not in Replit.
# -----------------------------------------------------------------------------

# ===== Replit dev workspace secrets (Tools > Secrets) =====
# Deploy/automation tokens used by the in-repo deploy helpers:
CLOUDFLARE_ACCOUNT_ID=          # Cloudflare account id (Pages deploys: web, admin, ads, mobile mirrors)
CLOUDFLARE_API_TOKEN=           # Cloudflare API token with Pages:Edit
GITHUB_TOKEN=                   # GitHub PAT (repo scope) for REST pushes — git CLI push is blocked here
RAILWAY_TOKEN=                  # Railway token (GraphQL API) — API server prod
SUPABASE_ACCESS_TOKEN=          # Supabase Management API token (schema/DDL automation)

# Backend/session + Supabase (server side):
SESSION_SECRET=                 # random long string for session signing
SUPABASE_SERVICE_ROLE_KEY=      # Supabase service role key (server only — NEVER expose to client)

# Vite build-time (client) — SAME Supabase project as the server:
VITE_SUPABASE_URL=              # https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=         # Supabase anon/public key
VITE_API_URL=                   # https://api.yourdomain.com (deployed API base; used by dev + mirror builds)

# ===== API server (Railway > Variables) — see artifacts/api-server/.env.example =====
# NODE_ENV, DATABASE_URL, SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
# SUPABASE_JWT_SECRET, R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY,
# R2_BUCKET, R2_PUBLIC_URL
# Plus (per project history) any Stripe + Stream (getstream.io) keys live on Railway:
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STREAM_API_KEY, STREAM_API_SECRET

# ===== Web / Admin / Ads (Cloudflare Pages > Settings > Environment variables) =====
# Build-time only — see artifacts/web/.env.example:
# VITE_API_URL, VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, BASE_PATH
