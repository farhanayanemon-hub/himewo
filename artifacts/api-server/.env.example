# ===== HiMewo API server (production) =====
# Copy these into your host's environment variables (e.g. Railway > Variables).

NODE_ENV=production
# PORT is provided automatically by most hosts (Railway). Set only if required.
# PORT=8080

# --- Database (Supabase Postgres) ---
# Supabase: Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Supabase Auth (Settings > API) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Cloudflare R2 object storage (images/files, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=media
# Public base URL of the bucket: an R2 public r2.dev URL OR a custom domain.
R2_PUBLIC_URL=https://media.yourdomain.com
