# ===== HiMewo web app (build-time env) =====
# These are read by Vite at BUILD time. Set them on your static host
# (e.g. Cloudflare Pages > Settings > Environment variables) before building.

# Base URL of the deployed API server (your Railway backend domain).
VITE_API_URL=https://api.yourdomain.com

# Supabase browser client — SAME project as the API server (Settings > API).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Path the app is served under. "/" for a root domain (this is the default).
BASE_PATH=/
